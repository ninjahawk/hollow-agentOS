{
  "name": "AgentOS",
  "version": "0.2.0",
  "description": "An operating environment designed exclusively for agentic AI — not humans.",
  "api": {
    "host": "0.0.0.0",
    "port": 7777,
    "token": "CHANGE-THIS-TO-A-REAL-SECRET"
  },
  "dashboard": {
    "host": "0.0.0.0",
    "port": 7778
  },
  "memory": {
    "path": "/agentOS/memory",
    "auto_index_interval_seconds": 30,
    "max_session_log_entries": 10000
  },
  "shell": {
    "output_format": "json",
    "block_interactive_prompts": true,
    "default_timeout_seconds": 30,
    "log_all_commands": true
  },
  "ollama": {
    "host": "http://localhost:11434",
    "default_model": "mistral-nemo:12b",
    "embed_model": "nomic-embed-text",
    "gpu": "rtx5070",
    "gpu_layers": -1,
    "context_length": 32768
  },
  "workspace": {
    "root": "/mnt/c/Users/YOUR_USERNAME/Desktop/Your Workspace",
    "index_extensions": [".py", ".js", ".ts", ".go", ".rs", ".c", ".cpp", ".h", ".json", ".yaml", ".yml", ".toml", ".md", ".sh", ".html", ".css", ".txt"]
  }
}
