# HollowOS environment configuration
# ─────────────────────────────────────────────────────────────────────────────
# Location on installed system: /etc/hollow/hollow.env
# Sourced by: hollow-agent.service (systemd EnvironmentFile)
#
# SETUP: After flashing HollowOS to USB, mount the EFI partition and edit this
# file to add your ANTHROPIC_API_KEY. Without it, wrapping falls back to local
# Ollama (lower quality but functional for discovery and running tools).

# ── Claude API (required for best quality) ───────────────────────────────────
# Get a key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Alternatively, if you have Claude Code installed, the OAuth credentials are
# used automatically — no API key needed:
# CLAUDE_CREDENTIALS_FILE=/home/hollow/.claude/.credentials.json

# ── Hollow community store ────────────────────────────────────────────────────
# The shared store where wrapped tools are published and downloaded.
# Everyone using Hollow connects to the same store — network effects.
HOLLOW_STORE_URL=https://store.hollow.os

# Override to use a private store (enterprise / air-gapped deployments):
# HOLLOW_STORE_URL=http://your-internal-store:7779

# ── Agent API ─────────────────────────────────────────────────────────────────
# API token for the local agent API (used by the browser UI to authenticate)
# Change this to something random before deploying to shared hardware.
HOLLOW_API_TOKEN=hollow-default-token-change-me

# ── Model configuration ───────────────────────────────────────────────────────
# Local Ollama model for cheap ops (monitoring, goal tracking, keyword search)
# Must be pulled before use: docker exec hollow-api ollama pull <model>
OLLAMA_DEFAULT_MODEL=qwen3.5:9b

# ── Developer access ──────────────────────────────────────────────────────────
# Password for the 'hollow' user (Ctrl+Alt+F2 → terminal access)
# CHANGE THIS before booting on shared or semi-public hardware.
HOLLOW_DEV_PASSWORD=changeme
