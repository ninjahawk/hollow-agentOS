# Runtime data — these are bind-mounted from the host at runtime
memory/
workspace/
logs/
config.json

# Git history — not needed in the image
.git/
.github/

# Python cache
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Dev / test artifacts
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.log

# Editor / OS junk
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# Local env / secrets
.env
.env.*
*.local

# Node (just in case)
node_modules/
