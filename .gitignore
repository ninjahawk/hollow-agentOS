# Runtime config — copy config.example.json to config.json
config.json

# Runtime data directories (bind-mounted from host at runtime, never committed)
memory/*
!memory/.gitkeep
workspace/*
!workspace/.gitkeep
logs/*
!logs/.gitkeep
ollama/install.log

# Store runtime data (wrappers stored here, not committed)
store/data/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# Editor
.vscode/
.idea/
*.swp
*.swo
